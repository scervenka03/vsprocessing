{
  "name": "vsprocessing",
  "displayName": "vsprocessing",
  "license": "MIT",
  "description": "Processing in vscode",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vsprocessing.runVSProcessing",
        "title": "Run VsProcessing"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "yarn run compile",
    "compile": "yarn run compile:codebed && tsc -p ./",
    "compile:codebed": "tsc -p ./packages/codebed",
    "watch": "tsc -watch -p ./",
    "watch:codebed": "tsc -watch -p ./packages/codebed",
    "recompile": "yarn run watch:codebed & yarn run watch",
    "pretest": "yarn run compile && yarn run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
